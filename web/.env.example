# Copy to .env.local for local development.

# Link to the Phase 1 Python prediction service
NEXT_PUBLIC_PREDICTION_API_URL=http://localhost:8000

# --- Phase 3: Authentication (Better Auth) ---
# MongoDB connection string (from MongoDB Atlas — see ../SETUP.md)
MONGODB_URI=
# A long random secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of this app
BETTER_AUTH_URL=http://localhost:3000
# Google OAuth client (Google Cloud Console — see ../SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Phase 6: AI (insights, news summaries, chatbot) ---
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Phase 7: email reports & alerts ---
# RESEND_API_KEY=
